# 프로젝트 실행 프로파일(로컬에서 복사해서 .env 로 사용)
APP_STAGE=dev

# ── Vault ────────────────────────────────────────────────
# VAULT_TOKEN 은 반드시 설정해야 한다 (bootstrap 필수값)
VAULT_TOKEN=
# 호스트/브라우저/CLI 경로. 클러스터 내부 ESO는 이 host URL이 아니라
# gitops/platform/external-services/vault-external.yaml 의 Service +
# EndpointSlice(172.18.0.8:8200) 경로를 사용한다.
# Vault Kubernetes auth kubernetes_host 는 API server 경로
# https://172.18.0.2:6443 을 사용하며 VAULT_ADDR 과 역할이 다르다.
VAULT_ADDR=https://vault.127.0.0.1.nip.io
VAULT_SKIP_VERIFY=true

# ── PostgreSQL (Docker k3d-hyhome network) ───────────────
POSTGRES_WRITE_ADDR=172.18.0.15
POSTGRES_WRITE_PORT=15432
POSTGRES_READ_ADDR=172.18.0.15
POSTGRES_READ_PORT=15433

# ── Valkey / Redis (Docker k3d-hyhome network) ───────────
VALKEY_ADDR=172.18.0.9
VALKEY_PORT=6379

# ── Observability stack (Docker k3d-hyhome network, warn-only) ────
# Prometheus  : 172.18.0.10:9090
# Loki        : 172.18.0.13:3100
# Tempo       : 172.18.0.12:3200
# Alloy OTLP  : 172.18.0.11:4317 (gRPC) / :4318 (HTTP)
# Grafana     : 172.18.0.14:3000

# ── TLS 인증서 경로 ────────────────────────────────────────
# 아래 파일이 없으면 bootstrap 이 실패한다.
# mkcert 로 발급: mkcert -cert-file secrets/certs/cert.pem -key-file secrets/certs/key.pem '*.127.0.0.1.nip.io'
# Root CA: $(mkcert -CAROOT)/rootCA.pem 과 rootCA-key.pem 을 secrets/certs/ 에 복사
CERT_DIR=secrets/certs
CERT_FILE=secrets/certs/cert.pem
KEY_FILE=secrets/certs/key.pem
ROOT_CA_FILE=secrets/certs/rootCA.pem
ROOT_CA_KEY_FILE=secrets/certs/rootCA-key.pem

# ── k3d 포트 바인딩 ───────────────────────────────────────
# 기본 direct host 포트는 80/443 이다. bootstrap-local.sh 는 호스트 443 이
# 이미 사용 중이면 k3d serverlb host binding 용 HTTPS 포트를 8443 으로 바꿀 수 있다.
# 외부 Traefik dynamic config 는 ingress-nginx LoadBalancer IP(기본 172.18.0.240):443 을
# backend 로 사용하므로 host-port fallback 값과 혼동하지 않는다.
K3D_HTTP_PORT=80
K3D_HTTPS_PORT=443

# ── ArgoCD ────────────────────────────────────────────────
ARGOCD_HOST=argocd.127.0.0.1.nip.io
