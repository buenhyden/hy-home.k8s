# 프로젝트 실행 프로파일(로컬에서 복사해서 .env 로 사용)
APP_STAGE=dev

# ── Vault ────────────────────────────────────────────────
# VAULT_TOKEN 은 반드시 설정해야 한다 (bootstrap 필수값)
VAULT_TOKEN=
VAULT_ADDR=https://vault.127.0.0.1.nip.io
VAULT_SKIP_VERIFY=true

# ── PostgreSQL (Docker infra_net) ─────────────────────────
POSTGRES_WRITE_ADDR=172.19.0.11
POSTGRES_WRITE_PORT=15432
POSTGRES_READ_ADDR=172.19.0.11
POSTGRES_READ_PORT=15433

# ── Valkey / Redis (Docker infra_net) ────────────────────
VALKEY_ADDR=172.19.0.12
VALKEY_PORT=6379

# ── Observability stack (Docker infra_net, warn-only) ────
# Prometheus  : 172.19.0.20:9090
# Loki        : 172.19.0.21:3100
# Tempo       : 172.19.0.22:3200
# Alloy OTLP  : 172.19.0.23:4317 (gRPC) / :4318 (HTTP)
# Grafana     : 172.19.0.24:3000

# ── TLS 인증서 경로 ────────────────────────────────────────
# 아래 파일이 없으면 bootstrap 이 실패한다.
# mkcert 로 발급: mkcert -cert-file secrets/certs/cert.pem -key-file secrets/certs/key.pem '*.127.0.0.1.nip.io'
# Root CA: $(mkcert -CAROOT)/rootCA.pem 과 rootCA-key.pem 을 secrets/certs/ 에 복사
CERT_DIR=secrets/certs
CERT_FILE=secrets/certs/cert.pem
KEY_FILE=secrets/certs/key.pem
ROOT_CA_FILE=secrets/certs/rootCA.pem
ROOT_CA_KEY_FILE=secrets/certs/rootCA-key.pem

# ── k3d 포트 바인딩 ───────────────────────────────────────
K3D_HTTP_PORT=80
K3D_HTTPS_PORT=443

# ── ArgoCD ────────────────────────────────────────────────
ARGOCD_HOST=argocd.127.0.0.1.nip.io
