{
  "customInstructions": "Enforce Template-First document routing through docs/99.templates/support/template-routing.md, then read the matching template under docs/99.templates/templates/. Implement explicit QA and CI/static validation phases before considering any implementation complete. MUST utilize workspace structured directories. Consult docs/00.agent-governance/memory/.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_DIR=\"${CODEX_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$(pwd)}}\"; CLAUDE_PROJECT_DIR=\"$PROJECT_DIR\" HY_HOME_K8S_HOOK_PROVIDER=codex bash \"$PROJECT_DIR/docs/00.agent-governance/hooks/session-start.sh\"",
            "timeout": 20
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_DIR=\"${CODEX_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$(pwd)}}\"; CLAUDE_PROJECT_DIR=\"$PROJECT_DIR\" HY_HOME_K8S_HOOK_PROVIDER=codex bash \"$PROJECT_DIR/docs/00.agent-governance/hooks/k8s-pre-edit.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env -i HOME=\"$HOME\" LANG=C.UTF-8 LC_ALL=C.UTF-8 PATH=/usr/bin:/bin CODEX_PROJECT_DIR=\"$CODEX_PROJECT_DIR\" CLAUDE_PROJECT_DIR=\"$CODEX_PROJECT_DIR\" HY_HOME_K8S_HOOK_PROVIDER=codex /usr/bin/bash --noprofile --norc \"$CODEX_PROJECT_DIR/docs/00.agent-governance/hooks/post-validate.sh\"",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_DIR=\"${CODEX_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$(pwd)}}\"; CLAUDE_PROJECT_DIR=\"$PROJECT_DIR\" HY_HOME_K8S_HOOK_PROVIDER=codex bash \"$PROJECT_DIR/docs/00.agent-governance/hooks/lifecycle-guard.sh\"",
            "timeout": 60
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_DIR=\"${CODEX_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$(pwd)}}\"; CLAUDE_PROJECT_DIR=\"$PROJECT_DIR\" HY_HOME_K8S_HOOK_PROVIDER=codex bash \"$PROJECT_DIR/docs/00.agent-governance/hooks/lifecycle-guard.sh\"",
            "timeout": 60
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_DIR=\"${CODEX_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$(pwd)}}\"; CLAUDE_PROJECT_DIR=\"$PROJECT_DIR\" HY_HOME_K8S_HOOK_PROVIDER=codex bash \"$PROJECT_DIR/docs/00.agent-governance/hooks/lifecycle-guard.sh\"",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
