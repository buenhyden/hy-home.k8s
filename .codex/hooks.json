{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_DIR=\"${CODEX_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$(pwd)}}\"; CLAUDE_PROJECT_DIR=\"$PROJECT_DIR\" bash \"$PROJECT_DIR/.claude/hooks/session-start.sh\"",
            "timeout": 20
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_DIR=\"${CODEX_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$(pwd)}}\"; CLAUDE_PROJECT_DIR=\"$PROJECT_DIR\" bash \"$PROJECT_DIR/.claude/hooks/k8s-pre-edit.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_DIR=\"${CODEX_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$(pwd)}}\"; CLAUDE_PROJECT_DIR=\"$PROJECT_DIR\" bash \"$PROJECT_DIR/.claude/hooks/post-validate.sh\"",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_DIR=\"${CODEX_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$(pwd)}}\"; CLAUDE_PROJECT_DIR=\"$PROJECT_DIR\" bash \"$PROJECT_DIR/.claude/hooks/lifecycle-guard.sh\"",
            "timeout": 60
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_DIR=\"${CODEX_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$(pwd)}}\"; CLAUDE_PROJECT_DIR=\"$PROJECT_DIR\" bash \"$PROJECT_DIR/.claude/hooks/lifecycle-guard.sh\"",
            "timeout": 60
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_DIR=\"${CODEX_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$(pwd)}}\"; CLAUDE_PROJECT_DIR=\"$PROJECT_DIR\" bash \"$PROJECT_DIR/.claude/hooks/lifecycle-guard.sh\"",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
