{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hy-home.k8s/schemas/document-profiles-7.schema.json",
  "title": "Document profile registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "$id",
    "schemaVersion",
    "baseline",
    "target",
    "profiles",
    "governanceCurrentOwners",
    "referenceCurrentPacks",
    "documentContracts",
    "programLineage"
  ],
  "properties": {
    "$schema": {
      "const": "https://json-schema.org/draft/2020-12/schema"
    },
    "$id": {
      "const": "https://hy-home.k8s/schemas/document-profiles-7.schema.json"
    },
    "schemaVersion": {
      "const": 7
    },
    "baseline": {
      "$ref": "#/$defs/baseline"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/profile"
      }
    },
    "governanceCurrentOwners": {
      "$ref": "#/$defs/governanceCurrentOwners"
    },
    "referenceCurrentPacks": {
      "$ref": "#/$defs/referenceCurrentPacks"
    },
    "documentContracts": {
      "$ref": "#/$defs/documentContracts"
    },
    "programLineage": {
      "$ref": "#/$defs/programLineage"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "governanceCurrentOwners": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profileId",
        "allowedStates",
        "paths"
      ],
      "properties": {
        "profileId": {
          "const": "governance/reference"
        },
        "allowedStates": {
          "type": "array",
          "prefixItems": [
            {
              "const": "active"
            },
            {
              "const": "accepted"
            }
          ],
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        },
        "paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^docs/00\\.agent-governance/(?!README\\.md$)(?!memory/).+\\.md$"
          }
        }
      }
    },
    "referenceCurrentPacks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profileId",
        "packs"
      ],
      "properties": {
        "profileId": {
          "const": "content/reference"
        },
        "packs": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/referenceCurrentPack"
          }
        }
      }
    },
    "referenceCurrentPack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "allowedStates",
        "members"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(audits|research)/[0-9]{4}-[0-9]{2}-[0-9]{2}-[^/]+$"
        },
        "allowedStates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "members": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(?!README\\.md$)[A-Za-z0-9][A-Za-z0-9._-]*\\.md$"
          }
        }
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sha",
        "count"
      ],
      "properties": {
        "sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roots",
        "rootFiles"
      ],
      "properties": {
        "roots": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "rootFiles": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "programLineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "programs"
      ],
      "properties": {
        "programs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/program"
          }
        }
      }
    },
    "program": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prd",
        "ard",
        "tranches",
        "followUps"
      ],
      "properties": {
        "prd": {
          "type": "string",
          "pattern": "^[0-9]{3}$"
        },
        "ard": {
          "type": "string",
          "pattern": "^[0-9]{4}$"
        },
        "tranches": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/programRelation"
          }
        },
        "followUps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/programFollowUp"
          }
        }
      }
    },
    "programRelation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spec",
        "order",
        "state",
        "reason",
        "decision"
      ],
      "properties": {
        "spec": {
          "type": "string",
          "pattern": "^[0-9]{3}$"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "state": {
          "enum": [
            "draft",
            "active",
            "done",
            "archived"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "pattern": "^[0-9]{4}$"
        }
      }
    },
    "programFollowUp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spec",
        "order",
        "state",
        "reason",
        "decision",
        "evidenceMode"
      ],
      "properties": {
        "spec": {
          "type": "string",
          "pattern": "^[0-9]{3}$"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "state": {
          "enum": [
            "draft",
            "active",
            "done",
            "archived"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "pattern": "^[0-9]{4}$"
        },
        "evidenceMode": {
          "enum": [
            "reciprocal-body",
            "successor-record"
          ]
        }
      }
    },
    "nonEmptyStringArray": {
      "allOf": [
        {
          "$ref": "#/$defs/stringArray"
        },
        {
          "minItems": 1
        }
      ]
    },
    "documentContracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valueContracts",
        "roleDecisions",
        "admissionPolicies",
        "lifecycleContracts",
        "evidencePredicates"
      ],
      "properties": {
        "valueContracts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/valueContract" }
        },
        "roleDecisions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/roleDecision" }
        },
        "admissionPolicies": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/admissionPolicy" }
        },
        "lifecycleContracts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/lifecycleContract" }
        },
        "evidencePredicates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidencePredicate" }
        }
      }
    },
    "scalarValue": {
      "type": ["string", "integer", "number", "boolean", "null"]
    },
    "constantConstraint": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "value"],
          "properties": {
            "source": { "enum": ["literal", "profile-id"] },
            "value": { "$ref": "#/$defs/scalarValue" }
          }
        }
      ]
    },
    "enumConstraint": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "values"],
          "properties": {
            "source": { "enum": ["literal", "status-domain"] },
            "values": {
              "type": "array",
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/scalarValue" }
            }
          }
        }
      ]
    },
    "conditionalConstraint": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["key", "operator", "value", "effect"],
          "properties": {
            "key": { "type": "string", "minLength": 1 },
            "operator": { "enum": ["equals", "not-equals"] },
            "value": { "$ref": "#/$defs/scalarValue" },
            "effect": { "enum": ["required", "forbidden"] }
          }
        }
      ]
    },
    "keyValueContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key", "kind", "nullable", "constant", "enum", "pattern", "conditional"
      ],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["string", "date", "integer", "number", "boolean"] },
        "nullable": { "type": "boolean" },
        "constant": { "$ref": "#/$defs/constantConstraint" },
        "enum": { "$ref": "#/$defs/enumConstraint" },
        "pattern": { "type": ["string", "null"], "minLength": 1 },
        "conditional": { "$ref": "#/$defs/conditionalConstraint" }
      }
    },
    "valueContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "profileIds", "keys"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "profileIds": { "$ref": "#/$defs/nonEmptyStringArray" },
        "keys": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/keyValueContract" }
        }
      }
    },
    "roleDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profileIds", "role", "sourceProfileId", "relationshipSection", "bodyRequirement"
      ],
      "properties": {
        "profileIds": { "$ref": "#/$defs/nonEmptyStringArray" },
        "role": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "sourceProfileId": { "type": ["string", "null"] },
        "relationshipSection": { "type": ["string", "null"], "minLength": 1 },
        "bodyRequirement": { "enum": ["body-contract", "heading-set", "none"] }
      }
    },
    "createAdmission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "states"],
      "properties": {
        "mode": { "enum": ["states", "paired", "baseline-only", "snapshot-only"] },
        "states": { "$ref": "#/$defs/stringArray" }
      }
    },
    "admissionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "profileIds", "create", "delete", "rename", "profileChange", "baselinePaths"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "profileIds": { "$ref": "#/$defs/nonEmptyStringArray" },
        "create": { "$ref": "#/$defs/createAdmission" },
        "delete": { "const": "deny" },
        "rename": { "const": "deny" },
        "profileChange": { "const": "deny" },
        "baselinePaths": { "$ref": "#/$defs/stringArray" }
      }
    },
    "lifecycleEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "predicateId"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "predicateId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
      }
    },
    "lifecycleContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "profileIds", "terminalStates", "edges"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "profileIds": { "$ref": "#/$defs/nonEmptyStringArray" },
        "terminalStates": { "$ref": "#/$defs/stringArray" },
        "edges": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/lifecycleEdge" }
        }
      }
    },
    "profileEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileId", "from", "to"],
      "properties": {
        "profileId": { "type": "string", "minLength": 1 },
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 }
      }
    },
    "evidenceRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileIds", "states", "minimum", "maximum"],
      "properties": {
        "profileIds": { "$ref": "#/$defs/nonEmptyStringArray" },
        "states": { "$ref": "#/$defs/nonEmptyStringArray" },
        "minimum": { "type": "integer", "minimum": 0 },
        "maximum": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "evidencePredicate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "profileEdges", "evidence", "relationship", "cardinality",
        "sameDiff", "bodyRequirement", "capabilities"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "profileEdges": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/profileEdge" }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidenceRequirement" }
        },
        "relationship": { "enum": ["self", "role-decision", "pair", "program-lineage"] },
        "cardinality": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minimum", "maximum"],
          "properties": {
            "minimum": { "type": "integer", "minimum": 1 },
            "maximum": { "type": ["integer", "null"], "minimum": 1 }
          }
        },
        "sameDiff": {
          "enum": [
            "self-status-and-body", "pair-created-or-status-changed",
            "target-and-last-relation-changed", "target-and-evidence-status-body-changed",
            "target-plan-task-status-changed", "pair-status-changed"
          ]
        },
        "bodyRequirement": { "enum": ["body-contract", "heading-set"] },
        "capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "rendered-link", "reciprocal-link", "program-lineage-closed",
              "task-terminal-evidence", "same-diff"
            ]
          }
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "enum": [
            "exact",
            "regex"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "frontmatter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "required",
        "allowed",
        "order"
      ],
      "properties": {
        "mode": {
          "enum": [
            "required",
            "forbidden",
            "not-applicable"
          ]
        },
        "required": {
          "$ref": "#/$defs/stringArray"
        },
        "allowed": {
          "$ref": "#/$defs/stringArray"
        },
        "order": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "headings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "allowed"
      ],
      "properties": {
        "required": {
          "$ref": "#/$defs/stringArray"
        },
        "allowed": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "appendContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parentProfileId",
        "parentH2",
        "entryHeadingLevel",
        "sectionHeadingLevel",
        "requiredSections"
      ],
      "properties": {
        "parentProfileId": {
          "type": "string",
          "minLength": 1
        },
        "parentH2": {
          "type": "string",
          "minLength": 1
        },
        "entryHeadingLevel": {
          "const": 3
        },
        "sectionHeadingLevel": {
          "const": 4
        },
        "requiredSections": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "identifierColumn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "column",
        "kind"
      ],
      "properties": {
        "column": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "requirement",
            "criterion",
            "work-item"
          ]
        }
      }
    },
    "bodyContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section",
        "tableHeading",
        "enforcedStatuses",
        "requiredColumns",
        "identifierColumns",
        "sourceLinkColumn",
        "targetLinkColumn",
        "allowedSourceProfileIds",
        "allowedTargetProfileIds",
        "reciprocalEvidence",
        "allowExplicitExclusion"
      ],
      "properties": {
        "section": {
          "type": "string",
          "minLength": 1
        },
        "tableHeading": {
          "type": "string",
          "minLength": 1
        },
        "enforcedStatuses": {
          "$ref": "#/$defs/stringArray"
        },
        "requiredColumns": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "identifierColumns": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifierColumn"
          }
        },
        "sourceLinkColumn": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "targetLinkColumn": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "allowedSourceProfileIds": {
          "$ref": "#/$defs/stringArray"
        },
        "allowedTargetProfileIds": {
          "$ref": "#/$defs/stringArray"
        },
        "reciprocalEvidence": {
          "type": "boolean"
        },
        "allowExplicitExclusion": {
          "type": "boolean"
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "class",
        "mode",
        "routes",
        "frontmatter",
        "statusDomain",
        "headings",
        "template",
        "sourceProfileIds",
        "placeholderPolicy",
        "appendContract",
        "bodyContract"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "class": {
          "enum": [
            "sdlc",
            "common",
            "governance",
            "readme",
            "exception"
          ]
        },
        "mode": {
          "enum": [
            "authored",
            "template",
            "frontmatter-free",
            "classification-only",
            "generated",
            "non-target"
          ]
        },
        "routes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/route"
          }
        },
        "frontmatter": {
          "$ref": "#/$defs/frontmatter"
        },
        "statusDomain": {
          "$ref": "#/$defs/stringArray"
        },
        "headings": {
          "$ref": "#/$defs/headings"
        },
        "template": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourceProfileIds": {
          "$ref": "#/$defs/stringArray"
        },
        "placeholderPolicy": {
          "enum": [
            "forbidden",
            "template-only"
          ]
        },
        "appendContract": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/appendContract"
            }
          ]
        },
        "bodyContract": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/bodyContract"
            }
          ]
        }
      }
    }
  }
}
