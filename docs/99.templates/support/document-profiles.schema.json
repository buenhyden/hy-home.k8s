{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hy-home.k8s/schemas/document-profiles-1.schema.json",
  "title": "Document profile registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "$id",
    "schemaVersion",
    "baseline",
    "target",
    "profiles",
    "programLineage"
  ],
  "properties": {
    "$schema": {
      "const": "https://json-schema.org/draft/2020-12/schema"
    },
    "$id": {
      "const": "https://hy-home.k8s/schemas/document-profiles-1.schema.json"
    },
    "schemaVersion": {
      "const": 1
    },
    "baseline": {
      "$ref": "#/$defs/baseline"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/profile"
      }
    },
    "programLineage": {
      "$ref": "#/$defs/programLineage"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sha",
        "count"
      ],
      "properties": {
        "sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roots",
        "rootFiles"
      ],
      "properties": {
        "roots": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "rootFiles": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "programLineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prd",
        "ard",
        "specs"
      ],
      "properties": {
        "prd": {
          "type": "string",
          "pattern": "^[0-9]{3}$"
        },
        "ard": {
          "type": "string",
          "pattern": "^[0-9]{4}$"
        },
        "specs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[0-9]{3}$"
          }
        }
      }
    },
    "nonEmptyStringArray": {
      "allOf": [
        {
          "$ref": "#/$defs/stringArray"
        },
        {
          "minItems": 1
        }
      ]
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "enum": [
            "exact",
            "regex"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "frontmatter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "required",
        "allowed",
        "order"
      ],
      "properties": {
        "mode": {
          "enum": [
            "required",
            "forbidden",
            "not-applicable"
          ]
        },
        "required": {
          "$ref": "#/$defs/stringArray"
        },
        "allowed": {
          "$ref": "#/$defs/stringArray"
        },
        "order": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "headings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "allowed"
      ],
      "properties": {
        "required": {
          "$ref": "#/$defs/stringArray"
        },
        "allowed": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "appendContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parentProfileId",
        "parentH2",
        "entryHeadingLevel",
        "sectionHeadingLevel",
        "requiredSections"
      ],
      "properties": {
        "parentProfileId": {
          "type": "string",
          "minLength": 1
        },
        "parentH2": {
          "type": "string",
          "minLength": 1
        },
        "entryHeadingLevel": {
          "const": 3
        },
        "sectionHeadingLevel": {
          "const": 4
        },
        "requiredSections": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "class",
        "mode",
        "routes",
        "frontmatter",
        "statusDomain",
        "headings",
        "template",
        "sourceProfileIds",
        "placeholderPolicy",
        "appendContract"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "class": {
          "enum": [
            "sdlc",
            "common",
            "governance",
            "readme",
            "exception"
          ]
        },
        "mode": {
          "enum": [
            "authored",
            "template",
            "frontmatter-free",
            "native",
            "generated",
            "non-target"
          ]
        },
        "routes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/route"
          }
        },
        "frontmatter": {
          "$ref": "#/$defs/frontmatter"
        },
        "statusDomain": {
          "$ref": "#/$defs/stringArray"
        },
        "headings": {
          "$ref": "#/$defs/headings"
        },
        "template": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourceProfileIds": {
          "$ref": "#/$defs/stringArray"
        },
        "placeholderPolicy": {
          "enum": [
            "forbidden",
            "template-only"
          ]
        },
        "appendContract": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/appendContract"
            }
          ]
        }
      }
    }
  }
}
