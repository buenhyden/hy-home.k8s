{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hy-home.k8s/contracts/validation-surfaces.schema.json",
  "title": "Affected-surface validation contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "pathSemantics",
    "lanes",
    "protectedLevels",
    "evidenceLanes",
    "validators",
    "ciJobs",
    "surfaces"
  ],
  "properties": {
    "$schema": {
      "const": "./validation-surfaces.schema.json"
    },
    "schemaVersion": {
      "const": 1
    },
    "pathSemantics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["separator", "matching", "caseSensitive", "precedence"],
      "properties": {
        "separator": {"const": "posix"},
        "matching": {"const": "exact-or-anchored-regex"},
        "caseSensitive": {"const": true},
        "precedence": {"const": "none"}
      }
    },
    "lanes": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": {
        "enum": [
          "affected",
          "staged",
          "all-files",
          "message/manual",
          "ci",
          "remote/live",
          "inventory"
        ]
      }
    },
    "protectedLevels": {
      "const": ["none", "review", "protected"]
    },
    "evidenceLanes": {
      "const": ["repo-static", "ci", "remote/live"]
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/validator"}
    },
    "ciJobs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/ciJob"}
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/surface"}
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": {"enum": ["exact", "regex"]},
        "value": {"type": "string", "minLength": 1}
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": {"enum": ["FAIL", "DEFER", "SKIP"]},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "argv", "lanes", "optional", "fallback", "evidenceLane"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "lanes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "optional": {"type": "boolean"},
        "fallback": {"$ref": "#/$defs/fallback"},
        "evidenceLane": {"type": "string"}
      }
    },
    "ciJob": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "output", "evidenceLane"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "output": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "evidenceLane": {"type": "string"}
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "routes",
        "validators",
        "ciJobs",
        "protectedLevel",
        "fallback",
        "evidenceLane"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "routes": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/route"}
        },
        "validators": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identifier"}
        },
        "ciJobs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identifier"}
        },
        "protectedLevel": {"enum": ["none", "review", "protected"]},
        "fallback": {"$ref": "#/$defs/fallback"},
        "evidenceLane": {"type": "string"}
      }
    }
  }
}
